            ".route(r -> r.path(\"/__path__\").filters(f -> f.stripPrefix(1)).uri(\"lb://myservice\"))",
            ".route(r -> r.path(\"/__path__\").filters(f -> f.stripPrefix(1)).uri(\"lb://nossl\"))",
