#!/usr/bin/env bash

# platty-update-check — periodic version check for Platty agent plugins.
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>
#   UPGRADE_AVAILABLE <old> <new>
#   (nothing) — up to date, disabled, unavailable, or check skipped

set -euo pipefail
umask 077

PLUGIN_NAME="${1:-}"
if [ "$PLUGIN_NAME" != "platty" ] && [ "$PLUGIN_NAME" != "platty-mcp" ]; then
  echo "Usage: platty-update-check <platty or platty-mcp> [--force | --mark-upgraded <old-version>]" >&2
  exit 2
fi
shift

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VERSION_FILE="${PLATTY_UPDATE_VERSION_FILE:-$PLUGIN_ROOT/VERSION}"

if [ -n "${PLATTY_UPDATE_STATE_DIR:-}" ]; then
  STATE_DIR="$PLATTY_UPDATE_STATE_DIR"
elif [ -n "${PLATTY_HOME:-}" ]; then
  STATE_DIR="$PLATTY_HOME/plugin-updates"
elif [ -n "${HOME:-}" ]; then
  STATE_DIR="$HOME/.platty/plugin-updates"
else
  exit 0
fi

CACHE_FILE="$STATE_DIR/last-update-check-$PLUGIN_NAME"
MARKER_FILE="$STATE_DIR/just-upgraded-from-$PLUGIN_NAME"
REMOTE_PATH="plugins/$PLUGIN_NAME/VERSION"
REMOTE_URL="${PLATTY_UPDATE_REMOTE_URL:-https://raw.githubusercontent.com/paradigmshift-labs/platty/main/$REMOTE_PATH}"

is_version() {
  printf '%s\n' "$1" | grep -qE '^[0-9]+(\.[0-9]+)+$'
}

is_remote_newer() {
  awk -v current_version="$1" -v remote_version="$2" '
    BEGIN {
      current_count = split(current_version, current_parts, ".")
      remote_count = split(remote_version, remote_parts, ".")
      part_count = current_count > remote_count ? current_count : remote_count

      for (part_index = 1; part_index <= part_count; part_index += 1) {
        current_part = part_index <= current_count ? current_parts[part_index] + 0 : 0
        remote_part = part_index <= remote_count ? remote_parts[part_index] + 0 : 0
        if (remote_part > current_part) exit 0
        if (remote_part < current_part) exit 1
      }

      exit 1
    }
  '
}

case "${PLATTY_PLUGIN_UPDATE_CHECK:-1}" in
  0|false|FALSE|off|OFF)
    exit 0
    ;;
esac

case "${1:-}" in
  --force)
    rm -f "$CACHE_FILE"
    shift
    ;;
  --mark-upgraded)
    OLD_VERSION="${2:-}"
    if ! is_version "$OLD_VERSION"; then
      echo "--mark-upgraded requires a numeric dotted version" >&2
      exit 2
    fi
    mkdir -p "$STATE_DIR"
    printf '%s\n' "$OLD_VERSION" > "$MARKER_FILE"
    rm -f "$CACHE_FILE"
    exit 0
    ;;
esac

if [ "$#" -ne 0 ]; then
  echo "Unknown argument: $1" >&2
  exit 2
fi

LOCAL=""
if [ -f "$VERSION_FILE" ]; then
  LOCAL="$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null || true)"
fi
if ! is_version "$LOCAL"; then
  exit 0
fi

if [ -f "$MARKER_FILE" ]; then
  OLD="$(tr -d '[:space:]' < "$MARKER_FILE" 2>/dev/null || true)"
  rm -f "$MARKER_FILE"
  mkdir -p "$STATE_DIR"
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  if is_version "$OLD"; then
    echo "JUST_UPGRADED $OLD $LOCAL"
  fi
  exit 0
fi

if [ -f "$CACHE_FILE" ]; then
  CACHED=""
  IFS= read -r CACHED < "$CACHE_FILE" || true
  case "$CACHED" in
    UP_TO_DATE\ *) CACHE_TTL=60 ;;
    UPGRADE_AVAILABLE\ *) CACHE_TTL=720 ;;
    *) CACHE_TTL=0 ;;
  esac

  STALE="$(find "$CACHE_FILE" -mmin "+$CACHE_TTL" 2>/dev/null || true)"
  if [ -z "$STALE" ] && [ "$CACHE_TTL" -gt 0 ]; then
    case "$CACHED" in
      UP_TO_DATE\ *)
        CACHED_VERSION="$(echo "$CACHED" | awk '{print $2}')"
        CACHED_EXTRA="$(echo "$CACHED" | awk '{print $3}')"
        if [ "$CACHED_VERSION" = "$LOCAL" ] && [ -z "$CACHED_EXTRA" ]; then
          exit 0
        fi
        ;;
      UPGRADE_AVAILABLE\ *)
        CACHED_OLD="$(echo "$CACHED" | awk '{print $2}')"
        CACHED_NEW="$(echo "$CACHED" | awk '{print $3}')"
        CACHED_EXTRA="$(echo "$CACHED" | awk '{print $4}')"
        if [ "$CACHED_OLD" = "$LOCAL" ] \
          && is_version "$CACHED_NEW" \
          && is_remote_newer "$CACHED_OLD" "$CACHED_NEW" \
          && [ -z "$CACHED_EXTRA" ]; then
          echo "UPGRADE_AVAILABLE $CACHED_OLD $CACHED_NEW"
          exit 0
        fi
        ;;
    esac
  fi
fi

mkdir -p "$STATE_DIR"

REMOTE=""
if command -v curl >/dev/null 2>&1; then
  REMOTE="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null || true)"
fi

REMOTE="$(echo "$REMOTE" | tr -d '[:space:]')"
if ! is_version "$REMOTE"; then
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  exit 0
fi

if ! is_remote_newer "$LOCAL" "$REMOTE"; then
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  exit 0
fi

echo "UPGRADE_AVAILABLE $LOCAL $REMOTE" > "$CACHE_FILE"
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE"
